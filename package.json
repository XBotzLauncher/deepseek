{
  "name": "deepseek",
  "version": "1.0.0",
  "description": "Unofficial Node.js client untuk [DeepSeek Chat](https://chat.deepseek.com) — reverse-engineered dari web API-nya langsung. Mendukung login, multi-turn conversation, upload file, dan thinking mode.",
