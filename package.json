    "axios-cookiejar-support": "^7.0.0",
    "crypto": "^1.0.1",
    "form-data": "^4.0.5",
    "https-proxy-agent": "^9.0.0",
    "playwright": "^1.59.1",
    "tough-cookie": "^6.0.1"
  },
